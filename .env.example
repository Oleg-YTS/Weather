# Telegram Bot Token
BOT_TOKEN=your_bot_token_here

# OpenWeatherMap API Key
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Groq API Key (ПРИОРИТЕТ — быстрый, бесплатный)
# Получить: https://console.groq.com/
GROQ_API_KEY=

# DeepSeek API Key (FALLBACK — если Groq недоступен)
# Получить: https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Server timezone
TIMEZONE=Europe/Moscow

# Proxy (оставьте пустым, если не нужен)
# Формат: socks5://user:pass@host:port  или  http://user:pass@host:port
PROXY_URL=

# ═══════════════════════════════════════
# Render.com — webhook режим
# ═══════════════════════════════════════
# Раскомментируйте для запуска на Render

# RENDER=true
# WEBHOOK_PATH=/webhook
# WEBHOOK_SECRET=случайная_строка_для_защиты_webhook
# RENDER_EXTERNAL_URL=https://your-app.onrender.com
